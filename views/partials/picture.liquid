{% comment %}
This is a partial to load all images in better sizes and better quality
{% endcomment %}

{% if imagesrc contains '/assets/images' %}

    <picture>
        <source srcset="{{ imagesrc }}.avif?width={{ width }}&height={{ height }}&quality=70" type="image/avif" alt="">
        <source srcset="{{ imagesrc }}.webp?width={{ width }}&height={{ height }}&quality=70" type="image/webp" alt="">
        <img class="{{ class }}" src="{{ imagesrc }}?width={{ width }}&height={{ height }}&quality=60" fetchpriority="{{ fetch }}" loading="{{ loading }}" alt="">
    </picture>

{% else %}

    <picture>
        <source srcset="{{ imagesrc }}?width={{ width }}&height={{ height }}&format=avif&quality=70" type="image/avif" alt="">
        <source srcset="{{ imagesrc }}?width={{ width }}&height={{ height }}&format=webp&quality=70" type="image/webp" alt="">
        <img class="{{ class }}" src="{{ imagesrc }}?width={{ width }}&height={{ height }}&quality=60" fetchpriority="{{ fetch }}" loading="{{ loading }}" alt="">
    </picture>

{% endif %}