{% render 'partials/head.liquid' %}
<main class="acccount"> 
    {% render 'partials/breadcrumbs.liquid',
        current_path: current_path,
    %}

    {% assign welcome_message = "Welkom op jouw account " | append: user.name | append: "!" %}

    {% render 'partials/general-heading.liquid',
        heading_level: 1,
        content: welcome_message,
    %}
    <section>
        <figure>
                {% render 'partials/picture.liquid',
                    imagesrc: chosen.memoji,
                    width: "150",
                    height: "150",
                    alt: plant.name,
                    class: "memoji",
                    fetch: "high",
                    loading: "eager",
                    view-transition: hoihoi,
                    view-transition-class: hoidoei,
                %}
        </figure>
        <article>
            
            {% render 'partials/general-heading.liquid',
                heading_level: 2,
                content: user.name,
            %}
            
            {% assign current_date = "now" | date: "%Y%m%d" %}
            {% assign birth_date = user.birthdate | date: "%Y%m%d" %}

            {% comment %} Calculate the difference between current year and birth year which comes to the age {% endcomment %}
            {% assign current_year = "now" | date: "%Y" %}
            {% assign birth_year = user.birthdate | date: "%Y" %}
            {% assign age = current_year | minus: birth_year %}

            {% comment %} 
            Check if the birth date is greater than the current date.
            if it is do -1 because they cannot party yet :)
            {% endcomment %}

            {% assign current_md = "now" | date: "%m%d" %}
            {% assign birth_md = user.birthdate | date: "%m%d" %}

            {% if birth_md > current_md %}
            {% assign age = age | minus: 1 %}
            {% endif %}

            <p>Age: {{ age }}</p>

            {% assign totalplantstext = "🪴 " | append: total_plants | append: " Planten verzameld" %}

            {% render 'partials/general-paragraph.liquid',
                class: "",
                content: totalplantstext,
            %}
        </article>
    </section>

    <section>
        {% assign progress = "Nog " | append: user.xp | append: "xp tot level 3" %}

        {% render 'partials/general-heading.liquid',
            heading_level: 2,
            content: progress,
        %}
        <label for="">{{ user.xp }}</label>

        <progress class="{{ zone_type }}sierlint" id="opdracht-{{ zone_name }}-{{ zone_slug }}" max="100" value="{{ progress }}"></progress>
    </section>

    <section>
        {% assign progress = "Speciaal voor jou " | append: user.name | append: " :)" %}
        {% render 'partials/general-heading.liquid',
            heading_level: 2,
            content: progress,
        %}
        <details>
            <summary>Jouw badges</summary>
            <p>hier komen jouw badges</p>
        </details>
        <details>
            <summary>Jouw voorkeuren</summary>
            <p>hier komen jouw voorkeuren</p>
            <input type="radio" id="color-mode-light" name="color-mode" />
            <label for="color-mode-light" title="Use dark mode">Light☾</label>

            <input type="radio" id="color-mode-dark" name="color-mode" />
            <label for="color-mode-dark" title="dark dark mode">Dark☼</label>

            <input type="radio" id="color-mode-auto" name="color-mode" checked="checked" />
            <label for="color-mode-auto" title="Use system light/dark mode setting">System</label>
        </details>
        <form action="/account" method="POST">
            <button class="styled reset">Voortgang wissen</button>
        </form>

        <a class="styled logout" href="/logout">Uitloggen</a>

    </section>
</main>
{% render 'partials/foot.liquid', current_path: current_path %}